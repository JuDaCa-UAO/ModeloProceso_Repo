# .env.local.example
#
# Copia este archivo como .env.local y rellena los valores reales.
# NUNCA subas .env.local a Git (está en .gitignore).
#
# Variables con NEXT_PUBLIC_ prefix son expuestas al browser.
# No incluir en estas variables secretos privados (API keys, tokens).

# ── N8N ─────────────────────────────────────────────────────────────────────
# URL base de la instancia de N8N (sin trailing slash)
# Ejemplo: https://n8n.tudominio.com
NEXT_PUBLIC_N8N_BASE_URL=

# ID del formulario de autodiagnóstico en N8N
# Lo encuentras en la URL del formulario: /form/{ID}
NEXT_PUBLIC_N8N_AUTODIAG_FORM_ID=

# ── Entorno ──────────────────────────────────────────────────────────────────
# Valores: development | staging | production
NEXT_PUBLIC_APP_ENV=development

# ── Logging ──────────────────────────────────────────────────────────────────
# Habilita logs verbose en consola (automático en development)
# NEXT_PUBLIC_VERBOSE_LOGGING=true
